{
    "framework": "nextjs",
    "installCommand": "npm install",
    "buildCommand": "prisma generate && next build",
    "devCommand": "npm run dev",
    "regions": [
        "bom1"
    ],
    "env": {
        "NODE_ENV": "production"
    },
    "headers": [
        {
            "source": "/api/(.*)",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "no-store"
                }
            ]
        }
    ]
}