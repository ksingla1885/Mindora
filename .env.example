
# =============================
# Mindora — Environment Variables
# Copy this file to .env.local and fill in your values.
# DO NOT commit .env.local or .env with real secrets.
# =============================

# ── App URL ────────────────────────────────────────────────────────────────
# Your deployed app URL (used by NextAuth, emails, etc.)
# On Vercel, set this to your production URL e.g. https://mindora.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Admin Credentials (used by prisma/seed.js and scripts/fix_admin.js) ──────
# Run `npm run fix-admin` (or `npx prisma db seed`) to create/reset the admin account
ADMIN_EMAIL=your_admin_email@example.com
ADMIN_PASSWORD=your_strong_admin_password_here

# ── Database (Supabase / PostgreSQL) ───────────────────────────────────────
# Pooled connection via pgBouncer (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection (used by Prisma migrations / introspection)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── NextAuth / Auth.js ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here
NEXTAUTH_SECRET=your_auth_secret_here   # Same value as AUTH_SECRET
# Must be your deployed URL in production (Vercel sets VERCEL_URL automatically)
NEXTAUTH_URL=http://localhost:3000

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here

# ── AWS S3 ─────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET_NAME=your_bucket_name
NEXT_PUBLIC_CLOUDFRONT_DOMAIN=your_cloudfront_domain.cloudfront.net

# ── Razorpay ───────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Redis (optional — app works without it, caching is disabled) ────────────
# Use a full URL OR individual host/port/password fields (not both)
# REDIS_URL=redis://default:password@host:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PREFIX=mindora:

# ── OpenAI ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── SMTP (Email) ────────────────────────────────────────────────────────────
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
# For Gmail, use an App Password (not your real password)
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=your_email@gmail.com

# ── WebSocket (optional — only if running a standalone socket server) ───────
NEXT_PUBLIC_WS_URL=http://localhost:3001
